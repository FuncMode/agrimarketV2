{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://agrimarketv2-production-6061.up.railway.app/api/:path*"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://agrimarketv2-production-6061.up.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "status": 404,
      "dest": "/404.html"
    }
  ]
}